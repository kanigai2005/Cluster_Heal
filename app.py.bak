# app.py - Complete Working SRE Platform with ESP Pod Monitoring
import streamlit as st
import pandas as pd
import time
import plotly.graph_objects as go
from datetime import datetime
import threading

# Import all modules
from dynamic_discovery import pod_discovery
from kafka_producer import kafka_producer
from kafka_consumer import kafka_consumer
from anomaly_detection import anomaly_detector
from config import config

# Page configuration
st.set_page_config(
    page_title="SRE Platform - ESP Pod Monitor",
    page_icon="🚀",
    layout="wide",
    initial_sidebar_state="expanded"
)

# Custom CSS for better styling
st.markdown("""
<style>
    .metric-card {
        background-color: #f0f2f6;
        padding: 15px;
        border-radius: 10px;
        margin: 5px 0;
    }
    .critical-alert {
        background-color: #ff4444;
        color: white;
        padding: 10px;
        border-radius: 5px;
        margin: 5px 0;
    }
    .warning-alert {
        background-color: #ffa500;
        color: white;
        padding: 10px;
        border-radius: 5px;
        margin: 5px 0;
    }
    .healthy-status {
        background-color: #00ff00;
        color: black;
        padding: 10px;
        border-radius: 5px;
        margin: 5px 0;
    }
    .pod-card {
        background-color: #262730;
        padding: 10px;
        border-radius: 8px;
        margin: 5px;
        border-left: 4px solid;
    }
</style>
""", unsafe_allow_html=True)

# Title
st.title("🚀 Autonomous SRE Platform")
st.caption("Real-time ESP Pod Monitoring | Prometheus → Kafka → Streamlit | ML Anomaly Detection")

# Initialize session state
if 'services_started' not in st.session_state:
    st.session_state.services_started = False
if 'alerts_history' not in st.session_state:
    st.session_state.alerts_history = []
if 'metrics_cache' not in st.session_state:
    st.session_state.metrics_cache = {}

# Sidebar
with st.sidebar:
    st.header("📊 Platform Status")
    
    # Pod Discovery Status
    st.subheader("🔍 ESP Pod Discovery")
    esp_pods = [k for k in pod_discovery.pods.keys() if 'esp' in k.lower()]
    st.metric("Discovered ESP Pods", len(esp_pods))
    
    if esp_pods:
        for pod_key in esp_pods:
            pod_name = pod_key.split('/')[-1]
            namespace = pod_key.split('/')[0]
            st.write(f"• **{pod_name}** ({namespace})")
    
    st.divider()
    
    # Kafka Status
    st.subheader("📡 Kafka Stream")
    if hasattr(kafka_producer, 'producer') and kafka_producer.producer:
        st.success("✅ Producer Connected")
    else:
        st.warning("⚠️ Producer Starting...")
    
    if hasattr(kafka_consumer, 'consumer') and kafka_consumer.consumer:
        st.success("✅ Consumer Connected")
        st.metric("Messages Received", kafka_consumer.message_count)
    else:
        st.warning("⚠️ Consumer Starting...")
    
    st.divider()
    
    # ML Anomaly Detection Status
    st.subheader("🧠 ML Anomaly Detection")
    trained_models = len(anomaly_detector.history)
    st.metric("Trained Models", trained_models)
    if trained_models > 0:
        st.progress(min(trained_models / 10, 1.0))
        st.caption(f"Learning from {trained_models} pods")
    else:
        st.progress(0)
        st.caption("Collecting training data...")
    
    st.divider()
    
    # Controls
    st.subheader("🎮 Controls")
    refresh_rate = st.slider("Refresh Rate (seconds)", 2, 10, 3)
    show_charts = st.checkbox("Show CPU Charts", value=True)
    auto_remediate = st.checkbox("Auto-remediate (Demo)", value=False)

# Start services (only once)
if not st.session_state.services_started:
    with st.spinner("🚀 Starting SRE Platform Services..."):
        # Start Kafka producer
        kafka_producer.start()
        # Start Kafka consumer
        kafka_consumer.start()
        # Initial pod discovery
        pod_discovery.discover_pods()
    st.session_state.services_started = True
    st.success("✅ All services started successfully!")

# Main dashboard - Two columns
col1, col2 = st.columns([2.5, 1.5])

with col1:
    st.subheader("📊 Real-time ESP Pod Metrics")
    metrics_container = st.container()
    if show_charts:
        chart_container = st.container()

with col2:
    st.subheader("🚨 Anomaly Alerts")
    alerts_container = st.container()
    st.subheader("🤖 AI Recommendations")
    recommendations_container = st.container()

# Helper function to determine pod status
def get_pod_status(cpu: float, memory_mb: float) -> tuple:
    """Returns (status_text, status_color, severity)"""
    if cpu > 0.9 or memory_mb > 1024:
        return ("CRITICAL", "#ff4444", "critical")
    elif cpu > 0.7 or memory_mb > 512:
        return ("WARNING", "#ffa500", "warning")
    elif cpu > 0.5:
        return ("DEGRADED", "#ffeb3b", "degraded")
    else:
        return ("HEALTHY", "#00ff00", "healthy")

# Main update loop placeholder
main_placeholder = st.empty()

# Update function
def update_dashboard():
    """Update the dashboard with latest metrics"""
    
    # Get latest metrics from Kafka consumer
    metrics = kafka_consumer.get_latest_metrics()
    
    if not metrics:
        with metrics_container:
            st.info("⏳ Waiting for metrics from Kafka...")
            st.caption("This may take 30-60 seconds for initial data collection")
            st.progress(0.3)
        return
    
    # Build records for display
    records = []
    alerts = []
    high_cpu_pods = []
    high_memory_pods = []
    
    for pod_key, m in metrics.items():
        pod_name = pod_key.split('/')[-1]
        namespace = m.get('namespace', 'unknown')
        cpu = m.get('cpu', 0)
        memory_mb = m.get('memory_mb', 0)
        
        # Skip if no data
        if cpu == 0 and memory_mb == 0:
            continue
        
        # Get status
        status, color, severity = get_pod_status(cpu, memory_mb)
        
        records.append({
            "Pod": pod_name,
            "Namespace": namespace,
            "CPU (cores)": f"{cpu:.3f}",
            "CPU %": f"{cpu*100:.1f}%",
            "Memory (MB)": f"{memory_mb:.0f}",
            "Status": status,
            "severity": severity,
            "cpu_raw": cpu,
            "mem_raw": memory_mb
        })
        
        # Track issues
        if cpu > 0.7:
            high_cpu_pods.append((pod_name, namespace, cpu))
        if memory_mb > 512:
            high_memory_pods.append((pod_name, namespace, memory_mb))
        
        # Create alerts
        if severity in ["critical", "warning"]:
            alerts.append({
                "pod": pod_name,
                "namespace": namespace,
                "cpu": cpu,
                "memory": memory_mb,
                "severity": severity,
                "timestamp": datetime.now()
            })
    
    if not records:
        with metrics_container:
            st.warning("No ESP pod metrics found. Checking...")
        return
    
    # Display metrics table
    with metrics_container:
        df = pd.DataFrame(records)
        
        # Apply color coding to Status column
        def color_status(val):
            if 'CRITICAL' in str(val):
                return 'background-color: #ff4444; color: white'
            elif 'WARNING' in str(val):
                return 'background-color: #ffa500; color: black'
            elif 'DEGRADED' in str(val):
                return 'background-color: #ffeb3b; color: black'
            elif 'HEALTHY' in str(val):
                return 'background-color: #00ff00; color: black'
            return ''
        
        styled_df = df[['Pod', 'Namespace', 'CPU %', 'Memory (MB)', 'Status']].style.applymap(
            color_status, subset=['Status']
        )
        
        st.dataframe(styled_df, use_container_width=True, hide_index=True)
        
        # Show CPU chart
        if show_charts and records:
            st.subheader("📈 CPU Usage by Pod")
            chart_df = pd.DataFrame([{
                "Pod": r["Pod"], 
                "CPU %": float(r["CPU %"].replace('%', ''))
            } for r in records])
            
            fig = go.Figure()
            fig.add_trace(go.Bar(
                x=chart_df["Pod"],
                y=chart_df["CPU %"],
                marker_color=['red' if x > 70 else 'orange' if x > 50 else 'green' for x in chart_df["CPU %"]],
                text=chart_df["CPU %"],
                textposition='auto',
            ))
            fig.add_hline(y=70, line_dash="dash", line_color="orange", 
                         annotation_text="Warning (70%)", annotation_position="top right")
            fig.add_hline(y=90, line_dash="dash", line_color="red",
                         annotation_text="Critical (90%)", annotation_position="top right")
            fig.update_layout(
                height=300,
                title="CPU Usage Percentage",
                xaxis_title="Pod",
                yaxis_title="CPU %",
                showlegend=False
            )
            st.plotly_chart(fig, use_container_width=True)
    
    # Display alerts
    with alerts_container:
        if alerts:
            st.caption(f"📢 {len(alerts)} active alert(s)")
            for alert in alerts[:5]:
                severity_icon = "🔴" if alert['severity'] == "critical" else "🟡"
                st.markdown(f"""
                <div class="pod-card" style="border-left-color: {'#ff4444' if alert['severity'] == 'critical' else '#ffa500'}">
                    <b>{severity_icon} {alert['pod'].upper()}</b><br>
                    <small>{alert['namespace']}</small><br>
                    <small>CPU: {alert['cpu']*100:.1f}% | Memory: {alert['memory']:.0f}MB</small><br>
                    <small>{alert['timestamp'].strftime('%H:%M:%S')}</small>
                </div>
                """, unsafe_allow_html=True)
            
            # Store in history
            st.session_state.alerts_history.extend(alerts)
            st.session_state.alerts_history = st.session_state.alerts_history[-20:]
        else:
            st.success("✅ No anomalies detected")
            st.caption("All ESP pods are operating normally")
    
    # Display AI recommendations
    with recommendations_container:
        if high_cpu_pods:
            st.warning("🔥 **High CPU Detected**")
            for pod_name, namespace, cpu in high_cpu_pods[:3]:
                st.code(f"kubectl scale deployment {pod_name} -n {namespace} --replicas=3", language="bash")
            st.caption("💡 Recommendation: Scale horizontally to distribute load")
        
        elif high_memory_pods:
            st.warning("💾 **High Memory Usage**")
            for pod_name, namespace, mem in high_memory_pods[:3]:
                st.code(f"kubectl rollout restart deployment {pod_name} -n {namespace}", language="bash")
            st.caption("💡 Recommendation: Restart pods to free memory")
        
        else:
            st.success("✅ System Healthy")
            st.caption("No remediation needed at this time")
            
            # Show recent alerts if any
            if st.session_state.alerts_history:
                with st.expander("📜 Recent Alert History"):
                    for alert in st.session_state.alerts_history[-5:]:
                        st.write(f"• {alert['timestamp'].strftime('%H:%M:%S')} - {alert['pod']}: {alert['severity']}")
    
    # Store metrics in cache for comparison
    st.session_state.metrics_cache = {r["Pod"]: {"cpu": r["cpu_raw"], "memory": r["mem_raw"]} for r in records}
    
    return len(records)

# Auto-refresh loop
refresh_count = 0
while True:
    pod_count = update_dashboard()
    
    if pod_count == 0:
        with main_placeholder:
            st.info("🔄 No ESP pods found. Waiting for Kubernetes discovery...")
    
    refresh_count += 1
    time.sleep(refresh_rate)
    st.rerun()
